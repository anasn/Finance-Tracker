rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "itxanasn@gmail.com";
    }

    function isLicensed() {
      return isAdmin() || (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hasValidLicense == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(docData) {
      return !('userId' in docData) || docData.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    (!('hasValidLicense' in request.resource.data) || request.resource.data.hasValidLicense == false);
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == userId &&
          (
            (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['hasValidLicense'])) ||
            (
              request.resource.data.hasValidLicense == true &&
              'licenseKey' in request.resource.data &&
              getAfter(/databases/$(database)/documents/licenses/$(request.resource.data.licenseKey)).data.status == 'active' &&
              getAfter(/databases/$(database)/documents/licenses/$(request.resource.data.licenseKey)).data.usedBy == request.auth.uid &&
              get(/databases/$(database)/documents/licenses/$(request.resource.data.licenseKey)).data.status == 'unused'
            )
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /licenses/{licenseKey} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.usedBy == request.auth.uid || resource.data.status == 'unused'));
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.status == 'unused' &&
        request.resource.data.status == 'active' &&
        request.resource.data.usedBy == request.auth.uid &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.hasValidLicense == true &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.licenseKey == licenseKey
      );
    }

    match /branding/{docId} {
      allow read: if isSignedIn() && isLicensed() && docId == request.auth.uid;
      allow create: if isSignedIn() && isLicensed() && docId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isLicensed() && docId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isLicensed() && docId == request.auth.uid;
    }
    match /customers/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /stockRecords/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /payments/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /bankPayments/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /expenses/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /purchases/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
    match /invoices/{docId} {
      allow read: if isSignedIn() && isLicensed() && isOwner(resource.data);
      allow create: if isSignedIn() && isLicensed() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isLicensed() && isOwner(resource.data) && isOwner(request.resource.data);
      allow delete: if isSignedIn() && isLicensed() && isOwner(resource.data);
    }
  }
}
