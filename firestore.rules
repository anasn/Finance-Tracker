rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(docData) {
      return docData.userId == request.auth.uid;
    }

    match /branding/{docId} {
      allow read: if isSignedIn() && docId == request.auth.uid;
      allow create: if isSignedIn() && docId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && docId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && docId == request.auth.uid;
    }
    match /customers/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /stockRecords/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /payments/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /bankPayments/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /expenses/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /purchases/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
    match /invoices/{docId} {
      allow read: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isValidId(docId) && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docId) && isOwner(resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(docId) && isOwner(resource.data);
    }
  }
}
